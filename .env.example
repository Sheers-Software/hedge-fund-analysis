# Server-side API keys (optional fallback when a request carries no in-app key).
#
# Local dev: copy this file to `.env.local` and fill in real values.
# Vercel:    add these in Project → Settings → Environment Variables, then redeploy.
#            (`.env.local` is gitignored and is NOT deployed.)

# Required for AI report generation. Get one at https://aistudio.google.com/
GEMINI_API_KEY=

# Recommended. Powers ticker search and the real-time data fallback used when
# Yahoo Finance is blocked on Vercel's IPs. Get one at https://finnhub.io/
FINNHUB_API_KEY=

# ── Meta GTM funnel (all client-exposed, hence NEXT_PUBLIC_) ──────────
# Meta Pixel ID. When set, the pixel loads and fires PageView / ViewContent /
# Lead / StartTrial / InitiateCheckout / Subscribe across the funnel. Leave
# blank in dev — all analytics calls become safe no-ops.
NEXT_PUBLIC_FB_PIXEL_ID=

# Stripe Payment Link for the $9/mo Pro plan. The "Upgrade" buttons send users
# here; on return with ?upgraded=1 the app flips them to Pro. If blank, upgrades
# unlock optimistically so the funnel stays testable locally.
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=

# Canonical site URL — used for OpenGraph/metadata absolute URLs.
NEXT_PUBLIC_SITE_URL=https://apexalpha.app
