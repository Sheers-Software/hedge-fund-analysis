# Server-side API keys (optional fallback when a request carries no in-app key).
#
# Local dev: copy this file to `.env.local` and fill in real values.
# Vercel:    add these in Project → Settings → Environment Variables, then redeploy.
#            (`.env.local` is gitignored and is NOT deployed.)

# Required for AI report generation. Get one at https://aistudio.google.com/
GEMINI_API_KEY=

# Recommended. Powers ticker search and the real-time data fallback used when
# Yahoo Finance is blocked on Vercel's IPs. Get one at https://finnhub.io/
FINNHUB_API_KEY=
